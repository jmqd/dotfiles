#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [ -z "$repo_root" ]; then
  exit 0
fi

cd "$repo_root"

has_strict_mode() {
  local file="$1"

  if grep -Eq '^[[:space:]]*set[[:space:]]+-[^#]*e[^#]*u[^#]*o[^#]*[[:space:]]+pipefail' "$file"; then
    return 0
  fi

  if grep -Eq '^[[:space:]]*set[[:space:]]+-o[[:space:]]+errexit' "$file" \
    && grep -Eq '^[[:space:]]*set[[:space:]]+-o[[:space:]]+nounset' "$file" \
    && grep -Eq '^[[:space:]]*set[[:space:]]+-o[[:space:]]+pipefail' "$file"; then
    return 0
  fi

  return 1
}

detect_shell() {
  local file="$1"

  case "$file" in
    *.bash|.bashrc)
      echo "bash"
      return 0
      ;;
    *.zsh|.zshrc)
      echo "zsh"
      return 0
      ;;
  esac

  if head -n 1 "$file" | grep -q 'bash'; then
    echo "bash"
  elif head -n 1 "$file" | grep -q 'zsh'; then
    echo "zsh"
  else
    echo "sh"
  fi
}

shell_files=()
while IFS= read -r -d '' file; do
  case "$file" in
    *.sh|*.bash|*.zsh|.bashrc|.zshrc)
      shell_files+=("$file")
      ;;
  esac
done < <(git ls-files -z)

failed=0

run_shellcheck() {
  local shell_name="$1"
  local file="$2"

  if command -v shellcheck >/dev/null 2>&1; then
    shellcheck -x -s "$shell_name" "$file"
    return $?
  fi

  if command -v nix >/dev/null 2>&1 && [ -f "$repo_root/flake.nix" ]; then
    local tmp_cache_dir
    tmp_cache_dir="$(mktemp -d)"
    if XDG_CACHE_HOME="$tmp_cache_dir" nix develop --quiet --no-write-lock-file --command shellcheck -x -s "$shell_name" "$file"; then
      rm -rf "$tmp_cache_dir"
      return 0
    fi
    rm -rf "$tmp_cache_dir"
    return 2
  fi

  return 3
}

if [ "${#shell_files[@]}" -eq 0 ]; then
  echo "pre-push: no shell files found; skipping shell checks"
else
  echo "pre-push: running shell checks"

  for file in "${shell_files[@]}"; do
    [ -f "$file" ] || continue

    shell_name="$(detect_shell "$file")"

    case "$shell_name" in
      bash)
        if ! bash -n "$file"; then
          echo "pre-push: syntax check failed for $file (bash)" >&2
          failed=1
        fi
        ;;
      zsh)
        if command -v zsh >/dev/null 2>&1; then
          if ! zsh -n "$file"; then
            echo "pre-push: syntax check failed for $file (zsh)" >&2
            failed=1
          fi
        else
          echo "pre-push: WARN zsh not found; skipped syntax check for $file"
        fi
        ;;
      *)
        if ! sh -n "$file"; then
          echo "pre-push: syntax check failed for $file (sh)" >&2
          failed=1
        fi
        ;;
    esac

    shellcheck_status=0
    if ! run_shellcheck "$shell_name" "$file"; then
      shellcheck_status=$?
      if [ "$shellcheck_status" -eq 1 ]; then
        echo "pre-push: shellcheck failed for $file" >&2
      else
        echo "pre-push: shellcheck unavailable for $file (install or enable nix)" >&2
        failed=1
      fi
    fi

    case "$file" in
      bin/*.sh)
        if ! has_strict_mode "$file"; then
          echo "pre-push: $file missing strict mode (set -euo pipefail)" >&2
          failed=1
        fi
        ;;
    esac
  done
fi

echo "pre-push: running secret scan"
if ! bin/lint-secrets.sh; then
  echo "pre-push: secret scan failed" >&2
  failed=1
fi

if [ "$failed" -ne 0 ]; then
  echo "pre-push: checks failed" >&2
  exit 1
fi

echo "pre-push: all checks passed"
