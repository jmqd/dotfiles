#!/usr/bin/env bash
set -euo pipefail

HIVE_STATE="${HIVE_STATE:-${HOME}/.local/share/agent-hive}"
HIVE_LABEL="agent-hive"
HIVE_IMAGE="${HIVE_IMAGE:-nixos/nix}"
HIVE_NIX_VOLUME="hive-nix-store"
HIVE_BACKEND="${HIVE_BACKEND:-docker}"


die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

require_backend() {
  case "$HIVE_BACKEND" in
    docker|host) ;;
    *) die "unsupported HIVE_BACKEND: $HIVE_BACKEND (expected docker or host)" ;;
  esac
}

docker_ready() {
  docker info >/dev/null 2>&1
}

docker_context_name() {
  docker context show 2>/dev/null || true
}

docker_context_endpoint() {
  local context="${1:-}"
  [ -n "$context" ] || return 0
  docker context inspect "$context" --format '{{ (index .Endpoints "docker").Host }}' 2>/dev/null || true
}

wait_for_docker() {
  local timeout="${HIVE_DOCKER_START_TIMEOUT_SECONDS:-30}"
  case "$timeout" in
    ''|*[!0-9]*) timeout=30 ;;
  esac
  [ "$timeout" -ge 1 ] || timeout=1

  local waited=0
  while [ "$waited" -lt "$timeout" ]; do
    if docker_ready; then
      return 0
    fi
    sleep 1
    waited=$((waited + 1))
  done
  docker_ready
}

try_start_docker() {
  local label="$1"
  shift
  printf 'info: hive starting docker runtime via %s\n' "$label" >&2
  "$@" >/dev/null 2>&1
}

auto_start_docker() {
  case "${HIVE_AUTO_START_DOCKER:-1}" in
    0|false|FALSE|no|NO) return 1 ;;
  esac

  local context endpoint
  context="$(docker_context_name)"
  endpoint="$(docker_context_endpoint "$context")"

  if [ -n "${HIVE_DOCKER_START_CMD:-}" ]; then
    printf 'info: hive starting docker runtime via HIVE_DOCKER_START_CMD\n' >&2
    bash -lc "$HIVE_DOCKER_START_CMD" >/dev/null 2>&1 || return 1
    wait_for_docker
    return $?
  fi

  if [ "$context" = "orbstack" ] || [[ "$endpoint" == *".orbstack/"* ]]; then
    if command -v orbctl >/dev/null 2>&1 && try_start_docker "orbctl start" orbctl start && wait_for_docker; then
      return 0
    fi
    case "${OSTYPE:-}" in
      darwin*)
        if command -v open >/dev/null 2>&1 && try_start_docker "open -ga OrbStack" open -ga OrbStack && wait_for_docker; then
          return 0
        fi
        ;;
    esac
  fi

  if [ "$context" = "colima" ] || [[ "$endpoint" == *".colima/"* ]]; then
    if command -v colima >/dev/null 2>&1 && try_start_docker "colima start" colima start && wait_for_docker; then
      return 0
    fi
  fi

  case "${OSTYPE:-}" in
    darwin*)
      if command -v open >/dev/null 2>&1 && try_start_docker "open -ga Docker" open -ga Docker && wait_for_docker; then
        return 0
      fi
      ;;
  esac
  if command -v orbctl >/dev/null 2>&1 && try_start_docker "orbctl start" orbctl start && wait_for_docker; then
    return 0
  fi
  if command -v colima >/dev/null 2>&1 && try_start_docker "colima start" colima start && wait_for_docker; then
    return 0
  fi
  case "${OSTYPE:-}" in
    darwin*)
      if command -v open >/dev/null 2>&1 && try_start_docker "open -ga OrbStack" open -ga OrbStack && wait_for_docker; then
        return 0
      fi
      ;;
  esac

  return 1
}

require_docker() {
  command -v docker >/dev/null 2>&1 || die "docker is not installed"
  docker_ready && return 0
  auto_start_docker && return 0

  local context endpoint details=""
  context="$(docker_context_name)"
  endpoint="$(docker_context_endpoint "$context")"
  if [ -n "$context" ] || [ -n "$endpoint" ]; then
    details=" ("
    if [ -n "$context" ]; then
      details="${details}context: $context"
    fi
    if [ -n "$endpoint" ]; then
      details="${details}${context:+, }endpoint: $endpoint"
    fi
    details="${details})"
  fi
  case "${HIVE_AUTO_START_DOCKER:-1}" in
    0|false|FALSE|no|NO)
      die "docker daemon is not running${details}; auto-start disabled via HIVE_AUTO_START_DOCKER=0"
      ;;
  esac
  die "docker daemon is not running${details}"
}

sha256_prefix() {
  local value="$1"
  if command -v sha256sum >/dev/null 2>&1; then
    printf '%s' "$value" | sha256sum | awk '{print substr($1, 1, 16)}'
  elif command -v shasum >/dev/null 2>&1; then
    printf '%s' "$value" | shasum -a 256 | awk '{print substr($1, 1, 16)}'
  elif command -v openssl >/dev/null 2>&1; then
    printf '%s' "$value" | openssl dgst -sha256 -r | awk '{print substr($1, 1, 16)}'
  else
    die "missing sha256 tool"
  fi
}

normalize_repo_root() {
  local repo="$1"
  [ -d "$repo/.git" ] || die "not a git repo: $repo"
  (
    cd "$repo"
    pwd -P
  )
}

repo_key_for_root() {
  local repo_root="$1"
  printf '%s-%s' "$(basename "$repo_root")" "$(sha256_prefix "$repo_root")"
}

agent_name() {
  local input="${1:-}"
  local digits=""
  case "$input" in
    agent-*) digits="${input#agent-}" ;;
    *) digits="$input" ;;
  esac
  case "$digits" in
    ''|*[!0-9]*) die "invalid agent id: $input" ;;
  esac
  local number
  number=$((10#$digits))
  [ "$number" -ge 1 ] || die "invalid agent id: $input"
  printf 'agent-%02d' "$number"
}

container_name() {
  local repo_key="$1"
  local agent="$2"
  printf 'hive-%s-%s' "$repo_key" "$agent"
}

worktree_dir() {
  local repo_key="$1"
  local agent="$2"
  printf '%s/worktrees/%s/%s' "$HIVE_STATE" "$repo_key" "$agent"
}

log_file() {
  local repo_key="$1"
  local agent="$2"
  printf '%s/logs/%s-%s.log' "$HIVE_STATE" "$repo_key" "$agent"
}

host_repo_dir() {
  local repo_key="$1"
  printf '%s/host/%s' "$HIVE_STATE" "$repo_key"
}

host_worktree_file() {
  local repo_key="$1"
  local agent="$2"
  printf '%s/%s.worktree' "$(host_repo_dir "$repo_key")" "$agent"
}

host_pid_file() {
  local repo_key="$1"
  local agent="$2"
  printf '%s/%s.pid' "$(host_repo_dir "$repo_key")" "$agent"
}

resolve_worktree_git_dir() {
  local worktree="$1"
  if [ -d "$worktree/.git" ]; then
    printf '%s\n' "$worktree/.git"
    return 0
  fi
  if [ -f "$worktree/.git" ]; then
    local first_line git_dir
    IFS= read -r first_line < "$worktree/.git" || true
    case "$first_line" in
      'gitdir: '*)
        git_dir="${first_line#gitdir: }"
        case "$git_dir" in
          /*) printf '%s\n' "$git_dir" ;;
          *) printf '%s\n' "$worktree/$git_dir" ;;
        esac
        return 0
        ;;
    esac
  fi
  return 1
}

ensure_worktree_excludes() {
  local worktree="$1"
  local git_dir exclude_file
  git_dir="$(resolve_worktree_git_dir "$worktree")" || return 0
  exclude_file="$git_dir/info/exclude"
  mkdir -p "$(dirname "$exclude_file")"
  if [ ! -f "$exclude_file" ] || ! grep -Fxq '.hive/' "$exclude_file"; then
    printf '.hive/\n' >> "$exclude_file"
  fi
}

remove_worktree() {
  local repo_root="$1"
  local worktree="$2"
  [ -e "$worktree" ] || return 0
  git -C "$repo_root" worktree remove --force "$worktree" >/dev/null 2>&1 || \
    git -C "$worktree" worktree remove --force "$worktree" >/dev/null 2>&1 || \
    die "failed to remove worktree: $worktree"
}

ensure_worktree() {
  local repo_root="$1"
  local repo_key="$2"
  local agent="$3"
  local worktree
  worktree="$(worktree_dir "$repo_key" "$agent")"
  mkdir -p "$(dirname "$worktree")"
  if [ -e "$worktree" ]; then
    remove_worktree "$repo_root" "$worktree"
  fi
  git -C "$repo_root" worktree add --detach "$worktree" HEAD >/dev/null
  ensure_worktree_excludes "$worktree"
  printf '%s\n' "$worktree"
}

container_exists() {
  local repo_key="$1"
  local agent="$2"
  docker ps -q \
    --filter "label=${HIVE_LABEL}" \
    --filter "label=hive.repo=${repo_key}" \
    --filter "label=hive.agent=${agent}" | grep -q .
}

parse_repo_flag() {
  local repo=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --repo)
        [ $# -ge 2 ] || die "--repo requires a path"
        repo="$2"
        shift 2
        ;;
      --repo=*)
        repo="${1#--repo=}"
        shift
        ;;
      *)
        break
        ;;
    esac
  done
  [ -n "$repo" ] || die "--repo is required"
  PARSED_REPO="$(normalize_repo_root "$repo")"
  REMAINING_ARGS=("$@")
}

launch_host_command() {
  local worktree="$1"
  local log_path="$2"
  local pid_path="$3"
  local command="$4"
  : > "$log_path"
  (
    cd "$worktree"
    bash -lc "$command"
  ) > "$log_path" 2>&1 &
  printf '%s\n' "$!" > "$pid_path"
}

launch_docker_command() {
  local container="$1"
  local log_path="$2"
  local command="$3"
  : > "$log_path"
  (
    docker exec "$container" bash -lc "$command"
  ) > "$log_path" 2>&1 &
}

cmd_up() {
  local repo="" agents=1 cmd="" host_store_ro=0 hardened=0

  while [ $# -gt 0 ]; do
    case "$1" in
      --repo)
        [ $# -ge 2 ] || die "--repo requires a path"
        repo="$2"
        shift 2
        ;;
      --repo=*)
        repo="${1#--repo=}"
        shift
        ;;
      --agents)
        [ $# -ge 2 ] || die "--agents requires a number"
        agents="$2"
        shift 2
        ;;
      --agents=*)
        agents="${1#--agents=}"
        shift
        ;;
      --cmd)
        [ $# -ge 2 ] || die "--cmd requires a command"
        cmd="$2"
        shift 2
        ;;
      --cmd=*)
        cmd="${1#--cmd=}"
        shift
        ;;
      --host-store-ro)
        host_store_ro=1
        shift
        ;;
      --hardened)
        hardened=1
        shift
        ;;
      *)
        die "unknown flag: $1"
        ;;
    esac
  done

  [ -n "$repo" ] || die "usage: hive up --repo <path> [--agents N] [--cmd \"...\"]"
  case "$agents" in
    ''|*[!0-9]*) die "--agents must be a positive integer" ;;
  esac
  [ "$agents" -ge 1 ] || die "--agents must be >= 1"

  local repo_root repo_key
  repo_root="$(normalize_repo_root "$repo")"
  repo_key="$(repo_key_for_root "$repo_root")"

  mkdir -p "$HIVE_STATE/worktrees/$repo_key" "$HIVE_STATE/logs" "$(host_repo_dir "$repo_key")"

  if [ "$HIVE_BACKEND" = docker ]; then
    require_docker
    if [ "$host_store_ro" -eq 0 ]; then
      docker volume inspect "$HIVE_NIX_VOLUME" >/dev/null 2>&1 || docker volume create "$HIVE_NIX_VOLUME" >/dev/null
    fi
  fi

  local i=1
  while [ "$i" -le "$agents" ]; do
    local agent worktree log_path pid_path container
    agent="$(printf 'agent-%02d' "$i")"
    worktree="$(worktree_dir "$repo_key" "$agent")"
    log_path="$(log_file "$repo_key" "$agent")"
    pid_path="$(host_pid_file "$repo_key" "$agent")"
    container="$(container_name "$repo_key" "$agent")"

    case "$HIVE_BACKEND" in
      docker)
        if container_exists "$repo_key" "$agent"; then
          : > "$log_path"
          i=$((i + 1))
          continue
        fi
        docker rm -f "$container" >/dev/null 2>&1 || true
        worktree="$(ensure_worktree "$repo_root" "$repo_key" "$agent")"

        local -a run_args
        run_args=(
          run -d
          --name "$container"
          --label "$HIVE_LABEL"
          --label "hive.repo=${repo_key}"
          --label "hive.agent=${agent}"
          -v "$worktree:$worktree"
          -v "$repo_root/.git:$repo_root/.git"
          -w "$worktree"
          -e "NIX_CONFIG=experimental-features = nix-command flakes"
        )
        if [ "$host_store_ro" -eq 1 ]; then
          run_args+=(-v "/nix/store:/nix/store:ro")
        else
          run_args+=(-v "${HIVE_NIX_VOLUME}:/nix")
        fi
        if [ "$hardened" -eq 1 ]; then
          run_args+=(--cap-drop=ALL --security-opt=no-new-privileges)
        fi
        run_args+=("$HIVE_IMAGE" sh -lc 'while :; do sleep 3600; done')
        docker "${run_args[@]}" >/dev/null

        : > "$log_path"
        if [ -n "$cmd" ]; then
          launch_docker_command "$container" "$log_path" "$cmd"
        fi
        ;;
      host)
        if [ ! -f "$(host_worktree_file "$repo_key" "$agent")" ] || [ ! -d "$worktree" ]; then
          worktree="$(ensure_worktree "$repo_root" "$repo_key" "$agent")"
          printf '%s\n' "$worktree" > "$(host_worktree_file "$repo_key" "$agent")"
        fi
        : > "$log_path"
        if [ -n "$cmd" ]; then
          launch_host_command "$worktree" "$log_path" "$pid_path" "$cmd"
        fi
        ;;
    esac

    i=$((i + 1))
  done
}

cmd_ls() {
  parse_repo_flag "$@"
  local repo_root repo_key
  repo_root="$PARSED_REPO"
  repo_key="$(repo_key_for_root "$repo_root")"

  case "$HIVE_BACKEND" in
    docker)
      require_docker
      docker ps \
        --filter "label=${HIVE_LABEL}" \
        --filter "label=hive.repo=${repo_key}" \
        --format 'table {{.Names}}\t{{.Status}}\t{{.Label "hive.repo"}}\t{{.Label "hive.agent"}}'
      ;;
    host)
      printf 'NAMES\tSTATUS\tREPO\tAGENT\n'
      local host_dir
      host_dir="$(host_repo_dir "$repo_key")"
      if [ -d "$host_dir" ]; then
        local file agent
        for file in "$host_dir"/*.worktree; do
          [ -e "$file" ] || continue
          agent="$(basename "$file" .worktree)"
          printf 'hive-%s-%s\t%s\t%s\t%s\n' "$repo_key" "$agent" 'Up' "$repo_key" "$agent"
        done
      fi
      ;;
  esac
}

cmd_exec() {
  parse_repo_flag "$@"
  set -- "${REMAINING_ARGS[@]}"
  [ $# -ge 2 ] || die "usage: hive exec --repo <path> <agent-id> <command...>"

  local repo_root repo_key agent command_string worktree container
  repo_root="$PARSED_REPO"
  repo_key="$(repo_key_for_root "$repo_root")"
  agent="$(agent_name "$1")"
  shift
  command_string="$*"

  case "$HIVE_BACKEND" in
    docker)
      require_docker
      container="$(container_name "$repo_key" "$agent")"
      local flags=()
      if [ -t 0 ]; then
        flags=(-it)
      fi
      docker exec "${flags[@]}" "$container" bash -lc "$command_string"
      ;;
    host)
      worktree="$(worktree_dir "$repo_key" "$agent")"
      [ -d "$worktree" ] || die "no hive worktree for ${agent} in repo ${repo_key}"
      (
        cd "$worktree"
        bash -lc "$command_string"
      )
      ;;
  esac
}

cmd_logs() {
  parse_repo_flag "$@"
  set -- "${REMAINING_ARGS[@]}"
  [ $# -ge 1 ] || die "usage: hive logs --repo <path> <agent-id>"

  local repo_root repo_key agent container
  repo_root="$PARSED_REPO"
  repo_key="$(repo_key_for_root "$repo_root")"
  agent="$(agent_name "$1")"

  case "$HIVE_BACKEND" in
    docker)
      require_docker
      container="$(container_name "$repo_key" "$agent")"
      docker logs -f "$container"
      ;;
    host)
      tail -f "$(log_file "$repo_key" "$agent")"
      ;;
  esac
}

cmd_down() {
  local keep_worktrees=0
  parse_repo_flag "$@"
  set -- "${REMAINING_ARGS[@]}"
  while [ $# -gt 0 ]; do
    case "$1" in
      --keep-worktrees)
        keep_worktrees=1
        shift
        ;;
      *)
        die "unknown flag: $1"
        ;;
    esac
  done

  local repo_root repo_key
  repo_root="$PARSED_REPO"
  repo_key="$(repo_key_for_root "$repo_root")"

  case "$HIVE_BACKEND" in
    docker)
      require_docker
      local containers
      containers="$(docker ps -aq --filter "label=${HIVE_LABEL}" --filter "label=hive.repo=${repo_key}")"
      if [ -n "$containers" ]; then
        printf '%s\n' "$containers" | xargs docker rm -f >/dev/null
      fi
      printf 'containers stopped for repo %s\n' "$repo_key"
      ;;
    host)
      local host_dir pid_file pid
      host_dir="$(host_repo_dir "$repo_key")"
      if [ -d "$host_dir" ]; then
        for pid_file in "$host_dir"/*.pid; do
          [ -e "$pid_file" ] || continue
          pid="$(cat "$pid_file" 2>/dev/null || true)"
          if [ -n "$pid" ]; then
            kill "$pid" >/dev/null 2>&1 || true
          fi
        done
      fi
      printf 'host agents stopped for repo %s\n' "$repo_key"
      ;;
  esac

  if [ "$keep_worktrees" -eq 0 ]; then
    local worktree_root worktree agent
    worktree_root="$HIVE_STATE/worktrees/$repo_key"
    if [ -d "$worktree_root" ]; then
      for worktree in "$worktree_root"/*; do
        [ -e "$worktree" ] || continue
        remove_worktree "$repo_root" "$worktree"
      done
    fi
    printf 'worktrees cleaned for repo %s\n' "$repo_key"
  fi

  local host_dir host_file
  host_dir="$(host_repo_dir "$repo_key")"
  if [ -d "$host_dir" ]; then
    for host_file in "$host_dir"/*; do
      [ -e "$host_file" ] || continue
      : > "$host_file"
      mv "$host_file" "$host_file.stopped"
    done
  fi
}

cmd_worktree() {
  parse_repo_flag "$@"
  set -- "${REMAINING_ARGS[@]}"
  [ $# -ge 1 ] || die "usage: hive worktree --repo <path> <agent-id>"

  local repo_root repo_key agent
  repo_root="$PARSED_REPO"
  repo_key="$(repo_key_for_root "$repo_root")"
  agent="$(agent_name "$1")"
  printf '%s\n' "$(worktree_dir "$repo_key" "$agent")"
}

usage() {
  cat <<EOF
usage: hive <command> [args]

backend:
  HIVE_BACKEND=docker|host (default: docker)
  HIVE_AUTO_START_DOCKER=0|1 (default: 1)
  HIVE_DOCKER_START_CMD='<command>' (optional override for daemon startup)
  HIVE_DOCKER_START_TIMEOUT_SECONDS=N (default: 30)

commands:
  up --repo <path> [--agents N] [--cmd "..."] [--host-store-ro] [--hardened]
  ls --repo <path>
  exec --repo <path> <agent-id> <command...>
  logs --repo <path> <agent-id>
  down --repo <path> [--keep-worktrees]
  worktree --repo <path> <agent-id>
EOF
  exit 1
}

require_backend
[ $# -ge 1 ] || usage

case "$1" in
  up) shift; cmd_up "$@" ;;
  ls) shift; cmd_ls "$@" ;;
  exec) shift; cmd_exec "$@" ;;
  logs) shift; cmd_logs "$@" ;;
  down) shift; cmd_down "$@" ;;
  worktree) shift; cmd_worktree "$@" ;;
  *) usage ;;
esac
